# SeChatbot Configuration

# Node Environment
NODE_ENV=development

# Bot Identity
BOT_NAME=SeChatbot
BOT_VERSION=1.0.0

# GitHub Repository
GITHUB_REPO=itszzl-sudo/sechat-security-chat-pwa-app
GITHUB_BRANCH=main

# Stripe (Payment Processing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...  # optional fixed price

# SeChat Server Communication
SECHAT_SERVER_URL=http://localhost:5173
SECHAT_BOT_API_KEY=your-bot-api-key-here
SECHAT_BOT_SECRET=your-bot-secret-here

# Domain Registrars (Phase 2)
NAMESILO_API_KEY=
CLOUDFLARE_API_TOKEN=

# Cloud Provider (Phase 2)
DIGITALOCEAN_PAT=

# USDT Wallet (Phase 2)
USDT_WALLET_PRIVATE_KEY=
USDT_WALLET_ADDRESS=
FUNDER_USDT_ADDRESS=

# Email (Phase 2)
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USER=admin@sechat1.com
IMAP_PASSWORD=
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=admin@sechat1.com
SMTP_PASSWORD=

# Database
DATABASE_PATH=./data/sechatbot.db

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/sechatbot.log

# Domain Registrars (Phase 2 - Adapter Pattern)
# Porkbun (recommended - best API for automation)
PORKBUN_API_KEY=
PORKBUN_SECRET_KEY=

# Cloudflare Registrar (cost price, great DNS)
CLOUDFLARE_API_TOKEN=

# NameSilo (reliable, XML API)
NAMESILO_API_KEY=

# AI Code Audit (for upgrade security review)
OPENAI_API_KEY=

# Wallet Security (auto-generated on first run)
ENCRYPTED_HOT_KEY=
KEY_PASSPHRASE=
COLD_WALLET_ADDRESS=
HOT_WALLET_DAILY_LIMIT=100
